#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = [
#     "typer",
# ]
# ///
"""Watch for tmux sessions and ensure each has a matching cmux workspace.

Polls the tmux server on an interval and creates a cmux workspace for any
session that doesn't already have one. Unlike cmux-adopt, this runs
continuously and adopts both attached and detached sessions — the only
requirement is that no cmux workspace already covers the session.
"""

import signal
import sys
import time
from typing import Annotated

import typer

from _cmux import Workspace, cmux_workspaces, create_workspace, tmux_sessions


def sync_once(*, quiet: bool = False) -> int:
    sessions = tmux_sessions()
    if not sessions:
        return 0

    covered = {ws.session_name for ws in cmux_workspaces()}
    adopted = 0

    for session in sorted(sessions, key=lambda s: s.name):
        if session.name in covered:
            continue

        ws = Workspace(
            title=session.name,
            cwd=session.path,
            tmux=True,
            session=session.name,
        )
        ref = create_workspace(ws)
        print(f"adopt  {session.name} -> {ref} ({session.path})")
        adopted += 1

    return adopted


def main(
    interval: Annotated[
        float,
        typer.Option("--interval", "-i", help="Seconds between polls"),
    ] = 5.0,
    once: Annotated[
        bool,
        typer.Option("--once", help="Run a single sync and exit"),
    ] = False,
) -> None:
    if once:
        sync_once()
        return

    signal.signal(signal.SIGINT, lambda *_: sys.exit(0))
    signal.signal(signal.SIGTERM, lambda *_: sys.exit(0))

    print(f"watching tmux sessions every {interval}s")
    while True:
        try:
            sync_once(quiet=True)
        except Exception as exc:
            print(f"error: {exc}", file=sys.stderr)
        time.sleep(interval)


if __name__ == "__main__":
    typer.run(main)
