#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = [
#     "typer",
# ]
# ///
"""Restore cmux workspaces from a cmux-dump file (TOML by default, or JSON).

The format is detected by extension (.json is JSON, anything else is TOML).
With no path, the default ~/.config/cmux/session-dump.toml is used, falling
back to session-dump.json when the TOML file is absent.

Skips workspaces whose title already exists, so it is safe to rerun.

Optional per-workspace fields control where the workspace runs:

  machine + tmux = true   mosh to the host and attach a tmux session named
                          after the workspace, started in cwd
  machine only            plain mosh to the host
  tmux = true only        attach a local tmux session, started in cwd
  neither                 plain local workspace

If `machine` matches the local hostname, the workspace is treated as local.
tmux sessions use `new-session -A`, so restores resume existing sessions.
The shell cds into cwd before launching tmux, so a freshly created session
starts there even if tmux's -c is bypassed.

Remote (mosh) workspaces get a "[mosh] " label on the cmux title. The label is
display-only: the tmux session name comes from the base title (or an explicit
`session` field), so the prefix and its slugified form never reach the remote.
"""

import json
import shlex
import socket
import subprocess
import tomllib
from dataclasses import dataclass
from pathlib import Path
from typing import Annotated, Optional

import typer

DEFAULT_DIR = Path.home() / ".config" / "cmux"
DEFAULT_TOML = DEFAULT_DIR / "session-dump.toml"
DEFAULT_JSON = DEFAULT_DIR / "session-dump.json"

# Label prefixed onto the cmux workspace title for remote (mosh) workspaces.
# It is display-only: the remote tmux session name is derived from the base
# title (or `session`), so the prefix never reaches the remote host.
MOSH_PREFIX = "[mosh] "


def local_hostnames() -> set[str]:
    hostname = socket.gethostname()
    return {hostname.lower(), hostname.split(".")[0].lower()}


@dataclass
class Workspace:
    title: str
    cwd: str
    color: str | None = None
    pinned: bool = False
    description: str | None = None
    machine: str | None = None
    tmux: bool = False
    session: str | None = None

    @classmethod
    def from_dump(cls, ws: dict) -> "Workspace":
        return cls(
            title=ws["title"],
            cwd=ws["cwd"],
            color=ws.get("color"),
            pinned=ws.get("pinned", False),
            description=ws.get("description"),
            machine=ws.get("machine"),
            tmux=ws.get("tmux", False),
            session=ws.get("session"),
        )

    @property
    def base_title(self) -> str:
        # The title without the display-only "[mosh] " label, so the prefix is
        # never doubled and never leaks into the tmux session name.
        title = self.title
        while title.startswith(MOSH_PREFIX):
            title = title[len(MOSH_PREFIX):]
        return title

    @property
    def display_title(self) -> str:
        # cmux workspace title: remote workspaces get the "[mosh] " label.
        if self.is_remote:
            return f"{MOSH_PREFIX}{self.base_title}"
        return self.base_title

    @property
    def session_name(self) -> str:
        # An explicit `session` overrides the title-derived name. Built from the
        # base title (not display_title), so the "[mosh] " label and its
        # slugified form never reach the remote tmux. tmux session names may
        # not contain ":" or ".".
        name = self.session or self.base_title
        return name.replace(":", "-").replace(".", "-").replace(" ", "-")

    @property
    def is_remote(self) -> bool:
        return bool(self.machine) and self.machine.lower() not in local_hostnames()

    def command(self) -> str | None:
        cwd = shlex.quote(self.cwd)
        tmux_command = (
            f"tmux new-session -A -s {shlex.quote(self.session_name)} -c {cwd}"
        )
        # cd first so a freshly created session lands in cwd even if tmux's
        # -c is bypassed; ";" (not "&&") so attaching to an existing session
        # still works when the directory is missing on the remote
        shell_command = f"cd {cwd}; {tmux_command}"

        if self.is_remote:
            if self.tmux:
                # mosh passes the command to mosh-server as a clean argv and
                # execs it directly (no remote login shell re-parse), so the
                # command is quoted once, only for the local cmux-pane shell.
                # The "--" stops mosh parsing "-c" as its own option.
                return (
                    f"mosh {shlex.quote(self.machine)} --"
                    f" sh -c {shlex.quote(shell_command)}"
                )
            return f"mosh {shlex.quote(self.machine)}"

        if self.tmux:
            return shell_command

        return None


def cmux(*args: str) -> str:
    result = subprocess.run(
        ["cmux", *args],
        capture_output=True,
        text=True,
        check=True,
    )
    return result.stdout.strip()


def workspace_action(ref: str, action: str, *extra: str) -> None:
    cmux("workspace-action", "--action", action, "--workspace", ref, *extra)


def restore(ws: Workspace) -> str:
    command = ws.command()

    # When we issue our own launch command (mosh and/or tmux), open the local
    # pane in a neutral dir. Otherwise the shell's tmux autoattach -- triggered
    # by a project .envrc (`use tmux`) -- execs a local tmux session before our
    # command runs, and the mosh/tmux command ends up nested inside it. The
    # command's own `cd` sets the real working directory. Plain workspaces keep
    # their cwd so their normal .envrc autoattach behaves as usual.
    local_cwd = str(Path.home()) if command else ws.cwd
    create_args = [
        "workspace", "create",
        "--name", ws.display_title,
        "--cwd", local_cwd,
        "--focus", "false",
    ]

    if command:
        create_args += ["--command", command]

    output = cmux(*create_args)
    ref = output.split()[-1]
    if not ref.startswith("workspace:"):
        raise RuntimeError(
            f"Unexpected cmux output creating {ws.display_title!r}: {output!r}"
        )
    if ws.color:
        workspace_action(ref, "set-color", "--color", ws.color)
    if ws.pinned:
        workspace_action(ref, "pin")
    if ws.description:
        workspace_action(ref, "set-description", "--description", ws.description)
    return ref


def main(
    source: Annotated[
        Optional[Path],
        typer.Argument(help="Dump file (default: ~/.config/cmux/session-dump.toml, falls back to .json)"),
    ] = None,
) -> None:
    if source is None:
        # Prefer TOML; fall back to JSON only if the TOML file is absent
        source = DEFAULT_TOML if DEFAULT_TOML.is_file() else DEFAULT_JSON
    if not source.is_file():
        raise typer.BadParameter(f"No dump file at {source}")

    if source.suffix == ".json":
        dumped = json.loads(source.read_text())
    else:
        dumped = tomllib.loads(source.read_text())["workspaces"]

    workspaces = [Workspace.from_dump(ws) for ws in dumped]

    existing = {
        ws["title"]
        for ws in json.loads(cmux("workspace", "list", "--json"))["workspaces"]
    }

    for ws in workspaces:
        # Compare against the displayed title, which carries the "[mosh] "
        # label for remote workspaces, so re-runs match and don't duplicate.
        if ws.display_title in existing:
            print(f"skip   {ws.display_title} (already exists)")
            continue
        existing.add(ws.display_title)

        ref = restore(ws)
        details = []
        if ws.is_remote:
            details.append(f"mosh:{ws.machine}")
        if ws.tmux:
            details.append(f"tmux:{ws.session_name}")
        suffix = f" ({', '.join(details)})" if details else ""
        print(f"create {ws.display_title} -> {ref}{suffix}")


if __name__ == "__main__":
    typer.run(main)
