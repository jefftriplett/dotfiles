#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = [
#     "typer",
# ]
# ///
"""Restore cmux workspaces from a cmux-dump file (TOML by default, or JSON).

The format is detected by extension (.json is JSON, anything else is TOML).
With no path, the default ~/.config/cmux/session-dump.toml is used, falling
back to session-dump.json when the TOML file is absent.

Skips workspaces whose title already exists, so it is safe to rerun.

Optional per-workspace fields control where the workspace runs:

  machine + tmux = true   mosh to the host and attach a tmux session named
                          after the workspace, started in cwd
  machine only            plain mosh to the host
  tmux = true only        attach a local tmux session, started in cwd
  neither                 plain local workspace

If `machine` matches the local hostname, the workspace is treated as local.
tmux sessions use `new-session -A`, so restores resume existing sessions.
The shell cds into cwd before launching tmux, so a freshly created session
starts there even if tmux's -c is bypassed.

Remote (mosh) workspaces get a "[mosh] " label on the cmux title. The label is
display-only: the tmux session name comes from the base title (or an explicit
`session` field), so the prefix and its slugified form never reach the remote.
"""

from pathlib import Path
from typing import Annotated, Optional

import typer

from _cmux import (
    Workspace,
    cmux_workspaces,
    create_workspace,
    default_dump_path,
    load_dump,
)


def main(
    source: Annotated[
        Optional[Path],
        typer.Argument(help="Dump file (default: ~/.config/cmux/session-dump.toml, falls back to .json)"),
    ] = None,
) -> None:
    if source is None:
        source = default_dump_path()
    if not source.is_file():
        raise typer.BadParameter(f"No dump file at {source}")

    workspaces = [Workspace.from_dump(ws) for ws in load_dump(source)]

    # from_cmux already strips the display-only "[mosh] " label, so both the
    # labelled and plain titles compare equal to a dump entry's base_title.
    existing = {open_ws.title for open_ws in cmux_workspaces()}

    for ws in workspaces:
        if ws.base_title in existing:
            print(f"skip   {ws.display_title} (already exists)")
            continue
        existing.add(ws.base_title)

        ref = create_workspace(ws)
        details = []
        if ws.is_remote:
            details.append(f"mosh:{ws.machine}")
        if ws.tmux:
            details.append(f"tmux:{ws.session_name}")
        suffix = f" ({', '.join(details)})" if details else ""
        print(f"create {ws.display_title} -> {ref}{suffix}")


if __name__ == "__main__":
    typer.run(main)
