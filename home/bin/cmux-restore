#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = []
# ///
"""Restore cmux workspaces from a cmux-dump JSON file.

Skips workspaces whose title already exists, so it is safe to rerun.

Usage: cmux-restore [input-file]   (default: ~/.config/cmux/session-dump.json)
"""

import json
import subprocess
import sys
from pathlib import Path


def cmux(*args: str) -> str:
    result = subprocess.run(
        ["cmux", *args],
        capture_output=True,
        text=True,
        check=True,
    )
    return result.stdout.strip()


def workspace_action(ref: str, action: str, *extra: str) -> None:
    cmux("workspace-action", "--action", action, "--workspace", ref, *extra)


def main() -> None:
    source = Path(
        sys.argv[1]
        if len(sys.argv) > 1
        else Path.home() / ".config" / "cmux" / "session-dump.json"
    )
    if not source.is_file():
        sys.exit(f"No dump file at {source}")

    dumped = json.loads(source.read_text())
    existing = {
        ws["title"]
        for ws in json.loads(cmux("workspace", "list", "--json"))["workspaces"]
    }

    for ws in dumped:
        title = ws["title"]
        if title in existing:
            print(f"skip   {title} (already exists)")
            continue

        output = cmux(
            "workspace",
            "create",
            "--name",
            title,
            "--cwd",
            ws["cwd"],
            "--focus",
            "false",
        )
        ref = output.split()[-1]
        if ws.get("color"):
            workspace_action(ref, "set-color", "--color", ws["color"])
        if ws.get("pinned"):
            workspace_action(ref, "pin")
        if ws.get("description"):
            workspace_action(ref, "set-description", "--description", ws["description"])
        print(f"create {title} -> {ref}")


if __name__ == "__main__":
    main()
