#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = []
# ///
"""Dump cmux workspace session (titles, cwds, colors, pins, descriptions) to JSON.

Usage: cmux-dump [output-file]   (default: ~/.config/cmux/session-dump.json)
"""

import json
import subprocess
import sys
from pathlib import Path


def main() -> None:
    out = Path(
        sys.argv[1]
        if len(sys.argv) > 1
        else Path.home() / ".config" / "cmux" / "session-dump.json"
    )
    out.parent.mkdir(parents=True, exist_ok=True)

    result = subprocess.run(
        ["cmux", "workspace", "list", "--json"],
        capture_output=True,
        text=True,
        check=True,
    )
    workspaces = [
        {
            "title": ws["title"],
            "cwd": ws["current_directory"],
            "color": ws["custom_color"],
            "pinned": ws["pinned"],
            "description": ws["description"],
        }
        for ws in json.loads(result.stdout)["workspaces"]
    ]

    out.write_text(json.dumps(workspaces, indent=2) + "\n")
    print(f"Saved {len(workspaces)} workspaces to {out}")


if __name__ == "__main__":
    main()
