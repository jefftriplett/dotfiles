#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = [
#     "tomli-w",
#     "typer",
# ]
# ///
"""Dump cmux workspace session (titles, cwds, colors, pins, descriptions).

cmux can't tell us whether a workspace is running mosh or tmux, so the
optional `machine` and `tmux` fields are hand-edited in the dump file and
preserved (matched by title) when re-dumping over an existing file.
Annotated entries whose workspaces are closed are kept too, so closing a
workspace doesn't lose its config. cmux-restore uses these fields to mosh
to a remote host and/or attach a tmux session.
"""

import json
import subprocess
import tomllib
from dataclasses import asdict, dataclass
from pathlib import Path
from typing import Annotated, Optional

import tomli_w
import typer

DEFAULT_OUTPUT = Path.home() / ".config" / "cmux" / "session-dump.toml"

# cmux-restore adds this display-only label to remote workspace titles. Strip
# it on dump so the file stores the base title (stable across re-dumps, and so
# the title-keyed merge of hand-edited fields keeps matching).
MOSH_PREFIX = "[mosh] "


def strip_mosh_prefix(title: str) -> str:
    while title.startswith(MOSH_PREFIX):
        title = title[len(MOSH_PREFIX):]
    return title


@dataclass
class Workspace:
    title: str
    cwd: str
    color: str | None = None
    pinned: bool = False
    description: str | None = None
    machine: str | None = None
    tmux: bool = False
    session: str | None = None

    @classmethod
    def from_cmux(cls, ws: dict) -> "Workspace":
        return cls(
            title=strip_mosh_prefix(ws["title"]),
            cwd=ws["current_directory"],
            color=ws["custom_color"],
            pinned=ws["pinned"],
            description=ws["description"],
        )

    @classmethod
    def from_dump(cls, ws: dict) -> "Workspace":
        return cls(
            title=ws["title"],
            cwd=ws["cwd"],
            color=ws.get("color"),
            pinned=ws.get("pinned", False),
            description=ws.get("description"),
            machine=ws.get("machine"),
            tmux=ws.get("tmux", False),
            session=ws.get("session"),
        )

    @property
    def annotated(self) -> bool:
        return bool(self.machine) or self.tmux or bool(self.session)

    def to_dict(self, compact: bool = False) -> dict:
        data = asdict(self)
        if compact:
            return {
                key: value
                for key, value in data.items()
                if value is not None and value is not False
            }
        return data


def load_previous(path: Path) -> dict[str, Workspace]:
    """Map titles to prior dump entries so hand-edited fields survive."""
    if not path.is_file():
        return {}
    try:
        if path.suffix == ".json":
            entries = json.loads(path.read_text())
        else:
            entries = tomllib.loads(path.read_text())["workspaces"]
        return {ws["title"]: Workspace.from_dump(ws) for ws in entries}
    except (json.JSONDecodeError, tomllib.TOMLDecodeError, KeyError, TypeError) as exc:
        print(f"Refusing to overwrite unparseable {path}: {exc}")
        print("Fix or remove the file, then re-run.")
        raise typer.Exit(code=1)


def main(
    output: Annotated[
        Optional[Path],
        typer.Argument(help="Output file (default: ~/.config/cmux/session-dump.toml)"),
    ] = None,
    as_json: Annotated[
        bool, typer.Option("--json", help="Write JSON (default is TOML unless file ends in .json)")
    ] = False,
    as_toml: Annotated[bool, typer.Option("--toml", help="Write TOML (the default)")] = False,
) -> None:
    if as_json and as_toml:
        raise typer.BadParameter("Pass only one of --json or --toml")

    if output is None:
        output = DEFAULT_OUTPUT.with_suffix(".json") if as_json else DEFAULT_OUTPUT
    # Default to TOML; emit JSON only when asked or the path ends in .json
    use_toml = not as_json and (as_toml or output.suffix != ".json")
    output.parent.mkdir(parents=True, exist_ok=True)

    result = subprocess.run(
        ["cmux", "workspace", "list", "--json"],
        capture_output=True,
        text=True,
        check=True,
    )
    previous = load_previous(output)
    workspaces = []
    for entry in json.loads(result.stdout)["workspaces"]:
        ws = Workspace.from_cmux(entry)
        prior = previous.pop(ws.title, None)
        if prior is not None:
            ws.machine = prior.machine
            ws.tmux = prior.tmux
            ws.session = prior.session
        workspaces.append(ws)

    # Keep annotated entries whose workspaces are no longer open
    kept = [ws for ws in previous.values() if ws.annotated]
    workspaces.extend(kept)

    if use_toml:
        # TOML has no null; drop empty/default fields instead
        cleaned = [ws.to_dict(compact=True) for ws in workspaces]
        content = tomli_w.dumps({"workspaces": cleaned})
    else:
        content = json.dumps([ws.to_dict() for ws in workspaces], indent=2) + "\n"

    # Write atomically so an interrupt can't corrupt hand-edited fields
    tmp = output.with_suffix(output.suffix + ".tmp")
    tmp.write_text(content)
    tmp.rename(output)

    note = f" (kept {len(kept)} closed annotated)" if kept else ""
    print(f"Saved {len(workspaces)} workspaces to {output}{note}")


if __name__ == "__main__":
    typer.run(main)
