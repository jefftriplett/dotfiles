# shellcheck shell=bash

__tmux_session_name() {
    # tmux session names may not contain ":" or ".". Keep the replacement
    # set in sync with Workspace.session_name in ~/bin/_cmux.py.
    local name="${1:-${TMUX_AUTOATTACH:-$(basename "$PWD")}}"

    name="${name//:/-}"
    name="${name//./-}"
    name="${name// /-}"
    printf '%s' "$name"
}

__tmux_set_title() {
    printf '\033]0;%s\007' "$1"
}

__tmux_target_machine() {
    printf '%s' "${TMUX_AUTOATTACH_MACHINE:-${TMUX_AUTOATTACH_HOST:-}}"
}

__tmux_target_path() {
    printf '%s' "${TMUX_AUTOATTACH_PATH:-}"
}

__tmux_remote_tmux_string() {
    local quoted
    local remote_command="tmux"

    for arg in "$@"; do
        printf -v quoted '%q' "$arg"
        remote_command="${remote_command} ${quoted}"
    done

    printf '%s' "$remote_command"
}

__tmux_remote_tmux_command() {
    printf 'bash -lc %q' "$(__tmux_remote_tmux_string "$@")"
}

# Sets __tmux_argv to the local command that attaches the remote session.
# Interactive attaches use mosh when available (matching cmux-restore),
# falling back to ssh. mosh passes the command to mosh-server as a clean
# argv, so it is quoted once; ssh re-parses on the remote, so it gets the
# extra %q layer.
__tmux_remote_attach_argv() {
    local machine="$1"
    shift
    local tmux_string
    tmux_string="$(__tmux_remote_tmux_string "$@")"

    if command -v mosh >/dev/null 2>&1; then
        __tmux_argv=(direnv exec / env mosh "$machine" -- bash -lc "$tmux_string")
    else
        __tmux_argv=(direnv exec / env ssh -t "$machine" "bash -lc $(printf '%q' "$tmux_string")")
    fi
}

__tmux_attach() {
    local machine="$1"
    local name="$2"
    local path
    path="$(__tmux_target_path)"

    if [[ -n "$machine" ]]; then
        if [[ -n "$path" ]]; then
            __tmux_remote_attach_argv "$machine" new-session -A -s "$name" -c "$path"
        else
            __tmux_remote_attach_argv "$machine" new-session -A -s "$name"
        fi
        "${__tmux_argv[@]}"
    else
        if [[ -n "$path" ]]; then
            tmux new-session -A -s "$name" -c "$path"
        else
            tmux new-session -A -s "$name"
        fi
    fi
}

tmux() {
    direnv exec / tmux "$@"
}

tmux-new() {
    local machine
    local name
    name="$(__tmux_session_name "$1")"
    machine="$(__tmux_target_machine)"

    if [[ -n "$machine" ]]; then
        __tmux_set_title "${machine}:${name}"
    else
        __tmux_set_title "$name"
    fi

    __tmux_attach "$machine" "$name"
}

tmux-go() {
    local machine
    local name
    name="$(__tmux_session_name "$1")"
    machine="$(__tmux_target_machine)"

    if [[ -n "$machine" ]]; then
        __tmux_set_title "${machine}:${name}"
        __tmux_attach "$machine" "$name"
        return $?
    fi

    __tmux_set_title "$name"

    if [[ -n "$TMUX" ]]; then
        tmux has-session -t "$name" 2>/dev/null || tmux new-session -d -s "$name"
        tmux switch-client -t "$name"
    else
        tmux new-session -A -s "$name"
    fi
}

tmux-resume() {
    tmux-go "$@"
}

tmux-attach() {
    tmux-go "$@"
}

tmux-ls() {
    local machine
    machine="$(__tmux_target_machine)"

    if [[ -n "$machine" ]]; then
        direnv exec / env ssh "$machine" "$(__tmux_remote_tmux_command list-sessions "$@")"
    else
        tmux list-sessions "$@"
    fi
}

tmux-kill() {
    local machine
    local name
    name="$(__tmux_session_name "$1")"
    machine="$(__tmux_target_machine)"

    if [[ -n "$machine" ]]; then
        direnv exec / env ssh "$machine" "$(__tmux_remote_tmux_command kill-session -t "$name")"
    else
        tmux kill-session -t "$name"
    fi
}

__tmux_autoattach() {
    local machine
    local name
    local path

    [[ $- == *i* ]] || return 0
    [[ -z "$TMUX" ]] || return 0
    [[ -t 1 ]] || return 0
    [[ -z "$NO_TMUX_AUTOATTACH" ]] || return 0
    command -v direnv >/dev/null 2>&1 || return 0

    eval "$(direnv export bash 2>/dev/null)"
    [[ -n "$TMUX_AUTOATTACH" ]] || return 0

    name="$(__tmux_session_name "$TMUX_AUTOATTACH")"
    machine="$(__tmux_target_machine)"
    path="$(__tmux_target_path)"

    if [[ -n "$machine" ]]; then
        __tmux_set_title "${machine}:${name}"
        if [[ -n "$path" ]]; then
            __tmux_remote_attach_argv "$machine" new-session -A -s "$name" -c "$path"
        else
            __tmux_remote_attach_argv "$machine" new-session -A -s "$name"
        fi
        exec "${__tmux_argv[@]}"
    else
        __tmux_set_title "$name"
        if [[ -n "$path" ]]; then
            exec direnv exec / env tmux new-session -A -s "$name" -c "$path"
        else
            exec direnv exec / env tmux new-session -A -s "$name"
        fi
    fi
}

__tmux_sessions() {
    [[ -z "$(__tmux_target_machine)" ]] || return 0
    tmux list-sessions -F '#S' 2>/dev/null
}

_tmux_session_completions() {
    local cur sessions
    cur="${COMP_WORDS[COMP_CWORD]}"
    sessions="$(__tmux_sessions)"
    mapfile -t COMPREPLY < <(compgen -W "$sessions" -- "$cur")
}

complete -F _tmux_session_completions tmux-go tmux-resume tmux-attach tmux-kill

alias t='tmux'
alias ta='tmux-go'
alias tn='tmux-new'
alias tk='tmux-kill'
alias tls='tmux-ls'
