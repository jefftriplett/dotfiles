# shellcheck shell=bash

layout_uv() {
    local venv_dir="${1:-.venv}"

    watch_file pyproject.toml uv.lock .python-version

    if [[ ! -d "$venv_dir" ]]; then
        if ! command -v uv >/dev/null 2>&1; then
            log_error "uv is required to create $venv_dir"
            return 1
        fi

        log_status "No virtual environment exists. Executing \`uv venv $venv_dir\` to create one."
        uv venv "$venv_dir"
    fi

    VIRTUAL_ENV="$(cd "$venv_dir" && pwd)"

    if [[ -d "$VIRTUAL_ENV/bin" ]]; then
        PATH_add "$VIRTUAL_ENV/bin"
    elif [[ -d "$VIRTUAL_ENV/Scripts" ]]; then
        PATH_add "$VIRTUAL_ENV/Scripts"
    else
        log_error "No bin directory found in $VIRTUAL_ENV"
        return 1
    fi

    export UV_ACTIVE=1
    export VIRTUAL_ENV
}

use_tmux() {
    local name="${1:-$(basename "$PWD")}"
    name="${name//:/-}"
    name="${name// /-}"
    export TMUX_AUTOATTACH="$name"
}
